{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16", // Change this from "commonjs"
    "moduleResolution": "Node16", // Ensure this matches (case-insensitive, but Node16 is standard)
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
